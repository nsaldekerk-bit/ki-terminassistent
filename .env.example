# Postgres (local Postgres now, Neon pooled string later)
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/ki_terminassistent"
DIRECT_URL="postgresql://postgres:PASSWORD@localhost:5432/ki_terminassistent"

# Anthropic Claude API — OPTIONAL.
# Only powers the FAQ's free-text understanding. Leave empty and the FAQ still
# answers opening hours, address, phone, services and your own entries from the
# rules engine; unknown questions honestly offer a callback instead of guessing.
# Set claude-haiku-4-5 to cut the per-question cost roughly 5x.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Secret for the 24h reminder cron (Vercel sends it as a Bearer token).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# NextAuth
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email: console (dev, logs only) | resend | smtp
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
